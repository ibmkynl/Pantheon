{
  "name": "pantheon",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "start:mcp": "pnpm --filter @pantheon/mcp-server start",
    "start:orchestrator": "pnpm --filter @pantheon/orchestrator start",
    "start": "pnpm --filter @pantheon/mcp-server start",
    "dev:mcp": "pnpm --filter @pantheon/mcp-server dev",
    "dev:orchestrator": "pnpm --filter @pantheon/orchestrator dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
